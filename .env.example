# העתק קובץ זה ל-.env ומלא את הערכים. אל תשתף את .env (מכיל מפתחות).

# מפתח Claude API — חובה לניתוח. השג ב: https://console.anthropic.com
ANTHROPIC_API_KEY=

# מודל הניתוח (ברירת מחדל סבירה מבחינת איכות/עלות):
# איכות מקסימלית: claude-opus-4-8 | מאוזן: claude-sonnet-4-6
ANALYSIS_MODEL=claude-sonnet-4-6

# אימייל ל-NCBI (מומלץ — מאפשר קצב בקשות גבוה יותר ל-PubMed):
NCBI_EMAIL=
# מפתח NCBI אופציונלי (לקצב גבוה יותר): https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=
